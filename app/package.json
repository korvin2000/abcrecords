{
  "name": "guitar-codex",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Кодекс Гитаристов — an antique-manuscript RPG-codex catalogue of musicians, rendered from pages/*.bio.json + *.bio.md",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:fable": "tsc -b && vite build --base=/fable/",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/cormorant-sc": "^5.2.0",
    "@fontsource-variable/cormorant-garamond": "^5.3.0",
    "clsx": "2.1.1",
    "framer-motion": "^12.42.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.3.2"
  }
}
